{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ItemRecord": {
        "description": "A named numeric value used in summary calculations.",
        "properties": {
          "name": {
            "description": "Human-readable item label",
            "title": "Name",
            "type": "string"
          },
          "value": {
            "description": "Numeric value associated with the item",
            "title": "Value",
            "type": "number"
          }
        },
        "required": [
          "name",
          "value"
        ],
        "title": "ItemRecord",
        "type": "object"
      },
      "ItemsSummaryRequest": {
        "description": "Request body for computing aggregate statistics over items.",
        "properties": {
          "adjustment_mode": {
            "default": "standard",
            "description": "Aggregation adjustment strategy",
            "enum": [
              "standard",
              "normalized"
            ],
            "title": "Adjustment Mode",
            "type": "string"
          },
          "items": {
            "description": "Collection of items to summarize",
            "items": {
              "$ref": "#/components/schemas/ItemRecord"
            },
            "title": "Items",
            "type": "array"
          },
          "operation": {
            "description": "Aggregation operation to apply",
            "enum": [
              "mean",
              "sum"
            ],
            "title": "Operation",
            "type": "string"
          }
        },
        "required": [
          "items",
          "operation"
        ],
        "title": "ItemsSummaryRequest",
        "type": "object"
      },
      "ItemsSummaryResponse": {
        "description": "Aggregate result for an items summary request.",
        "properties": {
          "count": {
            "description": "Number of items included in the calculation",
            "title": "Count",
            "type": "integer"
          },
          "result": {
            "description": "Computed aggregate value",
            "title": "Result",
            "type": "number"
          }
        },
        "required": [
          "result",
          "count"
        ],
        "title": "ItemsSummaryResponse",
        "type": "object"
      },
      "LoyaltyScoreRequest": {
        "description": "Request body for computing a loyalty score.",
        "properties": {
          "account_type": {
            "description": "Account classification label",
            "title": "Account Type",
            "type": "string"
          },
          "base_points": {
            "description": "Base loyalty points before tenure adjustment",
            "title": "Base Points",
            "type": "integer"
          },
          "months_active": {
            "description": "Number of months the account has been active",
            "title": "Months Active",
            "type": "integer"
          }
        },
        "required": [
          "account_type",
          "months_active",
          "base_points"
        ],
        "title": "LoyaltyScoreRequest",
        "type": "object"
      },
      "LoyaltyScoreResponse": {
        "description": "Computed loyalty score for an account.",
        "properties": {
          "account_type": {
            "description": "Echo of the submitted account type",
            "title": "Account Type",
            "type": "string"
          },
          "score": {
            "description": "Calculated loyalty score",
            "title": "Score",
            "type": "number"
          }
        },
        "required": [
          "score",
          "account_type"
        ],
        "title": "LoyaltyScoreResponse",
        "type": "object"
      },
      "ProrateAllocation": {
        "description": "Allocated share for a single part.",
        "properties": {
          "amount": {
            "description": "Allocated amount for this part",
            "title": "Amount",
            "type": "number"
          },
          "label": {
            "description": "Part identifier",
            "title": "Label",
            "type": "string"
          }
        },
        "required": [
          "label",
          "amount"
        ],
        "title": "ProrateAllocation",
        "type": "object"
      },
      "ProratePart": {
        "description": "A weighted portion of a total amount.",
        "properties": {
          "label": {
            "description": "Identifier for this portion",
            "title": "Label",
            "type": "string"
          },
          "weight": {
            "description": "Relative weight used in allocation",
            "title": "Weight",
            "type": "number"
          }
        },
        "required": [
          "label",
          "weight"
        ],
        "title": "ProratePart",
        "type": "object"
      },
      "ProrateRequest": {
        "description": "Request body for prorating a total across weighted parts.",
        "properties": {
          "denominator": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional explicit denominator; defaults to sum of weights when omitted",
            "title": "Denominator"
          },
          "parts": {
            "description": "Weighted parts that receive a share of the total",
            "items": {
              "$ref": "#/components/schemas/ProratePart"
            },
            "title": "Parts",
            "type": "array"
          },
          "strict_zero_weights": {
            "default": false,
            "description": "Apply strict validation when all part weights are zero",
            "title": "Strict Zero Weights",
            "type": "boolean"
          },
          "total": {
            "description": "Total amount to distribute",
            "title": "Total",
            "type": "number"
          }
        },
        "required": [
          "total",
          "parts"
        ],
        "title": "ProrateRequest",
        "type": "object"
      },
      "ProrateResponse": {
        "description": "Proration result with per-part allocations.",
        "properties": {
          "allocations": {
            "description": "Per-part allocated amounts",
            "items": {
              "$ref": "#/components/schemas/ProrateAllocation"
            },
            "title": "Allocations",
            "type": "array"
          },
          "denominator_used": {
            "description": "Denominator applied during proration",
            "title": "Denominator Used",
            "type": "number"
          }
        },
        "required": [
          "allocations",
          "denominator_used"
        ],
        "title": "ProrateResponse",
        "type": "object"
      },
      "ReportAggregateRequest": {
        "description": "Request body for aggregating nested group data.",
        "properties": {
          "groups": {
            "description": "Nested lists of values grouped for aggregation",
            "items": {
              "items": {},
              "type": "array"
            },
            "title": "Groups",
            "type": "array"
          },
          "metric": {
            "description": "Metric label included in the response",
            "title": "Metric",
            "type": "string"
          }
        },
        "required": [
          "groups",
          "metric"
        ],
        "title": "ReportAggregateRequest",
        "type": "object"
      },
      "ReportAggregateResponse": {
        "description": "Flattened aggregate summary for nested groups.",
        "properties": {
          "count": {
            "description": "Total number of scalar values across groups",
            "title": "Count",
            "type": "integer"
          },
          "first_value": {
            "description": "First scalar value encountered",
            "title": "First Value"
          },
          "metric": {
            "description": "Echo of the requested metric label",
            "title": "Metric",
            "type": "string"
          }
        },
        "required": [
          "metric",
          "count",
          "first_value"
        ],
        "title": "ReportAggregateResponse",
        "type": "object"
      },
      "UserFilter": {
        "description": "Filter criteria for locating a user record.",
        "properties": {
          "field": {
            "description": "Key on the user object to compare",
            "title": "Field",
            "type": "string"
          },
          "value": {
            "description": "Expected value for the filter field",
            "title": "Value"
          }
        },
        "required": [
          "field",
          "value"
        ],
        "title": "UserFilter",
        "type": "object"
      },
      "UsersLookupRequest": {
        "description": "Request body for finding a user matching filter criteria.",
        "properties": {
          "filter": {
            "$ref": "#/components/schemas/UserFilter",
            "description": "Filter used to select a user"
          },
          "users": {
            "description": "List of user records as arbitrary key-value objects",
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Users",
            "type": "array"
          }
        },
        "required": [
          "users",
          "filter"
        ],
        "title": "UsersLookupRequest",
        "type": "object"
      },
      "UsersLookupResponse": {
        "description": "Matched user record from a lookup request.",
        "properties": {
          "user": {
            "additionalProperties": true,
            "description": "First user matching the filter",
            "title": "User",
            "type": "object"
          }
        },
        "required": [
          "user"
        ],
        "title": "UsersLookupResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Internal business operations API",
    "title": "Chaos QA Swarm Target API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/items/summary": {
      "post": {
        "description": "Compute mean or sum over a list of items.",
        "operationId": "items_summary_api_items_summary_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ItemsSummaryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemsSummaryResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Items Summary",
        "tags": [
          "items"
        ]
      }
    },
    "/api/loyalty/score": {
      "post": {
        "description": "Compute a loyalty score from account tenure and base points.",
        "operationId": "loyalty_score_api_loyalty_score_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoyaltyScoreRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoyaltyScoreResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Loyalty Score",
        "tags": [
          "loyalty"
        ]
      }
    },
    "/api/prorate": {
      "post": {
        "description": "Distribute a total amount across weighted parts.",
        "operationId": "prorate_api_prorate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProrateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProrateResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Prorate",
        "tags": [
          "prorate"
        ]
      }
    },
    "/api/report/aggregate": {
      "post": {
        "description": "Flatten nested groups and return aggregate metadata.",
        "operationId": "report_aggregate_api_report_aggregate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportAggregateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportAggregateResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Report Aggregate",
        "tags": [
          "report"
        ]
      }
    },
    "/api/users/lookup": {
      "post": {
        "description": "Return the first user matching the provided filter.",
        "operationId": "users_lookup_api_users_lookup_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UsersLookupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsersLookupResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Users Lookup",
        "tags": [
          "users"
        ]
      }
    },
    "/health": {
      "get": {
        "description": "Health check endpoint.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    }
  }
}
